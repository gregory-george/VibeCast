@page "/"
@rendermode InteractiveServer
@inject IDbContextFactory<AppDbContext> DbContextFactory
@inject EpisodeStateService EpisodeStateService
@inject ShowNotesSanitizer ShowNotesSanitizer
@inject DownloadQueue DownloadQueue
@inject DownloadProgressTracker ProgressTracker
@inject PlaybackService PlaybackService
@inject AppConfig Config
@using Microsoft.EntityFrameworkCore
@using VibeCast.AppHost
@using VibeCast.Data
@using VibeCast.Downloads
@using VibeCast.Episodes
@implements IDisposable

<PageTitle>VibeCast</PageTitle>

<div class="library">
    <nav class="feed-sidebar">
        <h1 class="app-brand"><img src="images/vibecast.png" alt="" class="app-logo" />VibeCast</h1>
        <ul>
            <li>
                <button class="@(selectedFeedId is null ? "selected" : null)" @onclick="() => SelectFeedAsync(null)">
                    <span class="feed-name">All feeds</span>
                    <span class="feed-metrics">
                        <span class="feed-time" title="Total time of new episodes">@FormatTotalTime(feeds?.Sum(f => f.UnplayedSeconds) ?? 0)</span>
                        <span class="count">@(feeds?.Sum(f => f.ActiveCount) ?? 0)</span>
                    </span>
                </button>
            </li>
            <li class="feed-filter">
                <label>
                    <input type="checkbox" checked="@Config.HideEmptyFeeds" @onchange="ToggleHideEmptyFeedsAsync" />
                    Hide feeds with no unplayed episodes
                </label>
            </li>
            @if (feeds is not null)
            {
                @foreach (var feed in feeds.Where(f => !Config.HideEmptyFeeds || f.ActiveCount > 0))
                {
                    <li>
                        <button class="@(selectedFeedId == feed.Id ? "selected" : null)" @onclick="() => SelectFeedAsync(feed.Id)">
                            <span class="feed-name" title="@feed.Title">
                                @if (feed.HasArtwork)
                                {
                                    <img class="feed-art" src="/media/feeds/@(feed.Id)/artwork" alt="" />
                                }
                                <span class="feed-title-text">@feed.Title</span>
                            </span>
                            <span class="feed-metrics">
                                <span class="feed-time" title="Total time of new episodes">@FormatTotalTime(feed.UnplayedSeconds)</span>
                                <span class="count">@feed.ActiveCount</span>
                            </span>
                        </button>
                    </li>
                }
            }
        </ul>
        <p><a href="/feeds">Manage feeds</a></p>
        <p><a href="/downloads">Downloads</a></p>
        <p><a href="/settings">Settings</a></p>
    </nav>

    <section class="episode-list">
        <div class="episode-list-header">
            <h2>@(showArchived ? "Archived" : "Episodes")</h2>
            <label>
                <input type="checkbox" checked="@showArchived" @onchange="ToggleShowArchivedAsync" />
                Show archived
            </label>
            <button @onclick="ToggleSortOrderAsync" title="Toggle sort order">
                @(Config.EpisodeSortDescending ? "Newest first ↓" : "Oldest first ↑")
            </button>
        </div>

        @if (episodes is null)
        {
            <p>Loading...</p>
        }
        else if (episodes.Count == 0)
        {
            <p>@(showArchived ? "No archived episodes." : "No episodes yet.")</p>
        }
        else
        {
            <ul>
                @foreach (var episode in episodes)
                {
                    <li class="@(selectedEpisodeId == episode.Id ? "selected" : null)" @onclick="() => SelectEpisodeAsync(episode.Id)">
                        <div class="episode-title">
                            @episode.Title
                            @if (episode.IsShort)
                            {
                                <span class="shorts-badge" title="YouTube Short">Short</span>
                            }
                            @if (episode.ScheduledStartUtc is not null)
                            {
                                <span class="upcoming-badge" title="@UpcomingTooltip(episode.ScheduledStartUtc)">Upcoming</span>
                            }
                        </div>
                        <div class="episode-meta">
                            @episode.FeedTitle &middot; @episode.PublishedAtUtc.ToLocalTime().ToString("MMM d, yyyy") &middot; @FormatDurationOrSchedule(episode.DurationSeconds, episode.ScheduledStartUtc) &middot; @FormatFileSize(episode.FileSizeBytes)
                        </div>
                    </li>
                }
            </ul>
        }
    </section>

    <section class="episode-detail">
        @if (detail is null)
        {
            <p>Select an episode.</p>
        }
        else
        {
            <h2>
                @detail.Title
                @if (detail.IsShort)
                {
                    <span class="shorts-badge" title="YouTube Short">Short</span>
                }
                @if (detail.ScheduledStartUtc is not null)
                {
                    <span class="upcoming-badge" title="@UpcomingTooltip(detail.ScheduledStartUtc)">Upcoming</span>
                }
            </h2>
            <p class="episode-meta">
                @detail.FeedTitle &middot; @detail.PublishedAtUtc.ToLocalTime().ToString("MMM d, yyyy") &middot; @FormatDurationOrSchedule(detail.DurationSeconds, detail.ScheduledStartUtc) &middot; @FormatFileSize(detail.FileSizeBytes)
            </p>

            <p>
                <label>
                    <input type="checkbox" checked="@detail.IsPlayed" @onchange="() => TogglePlayedAsync(detail)" />
                    Played
                </label>
                @if (detail.IsArchived)
                {
                    <button @onclick="() => UnarchiveAsync(detail.Id)">Unarchive</button>
                }
            </p>

            @if (detail.IsRss)
            {
                <p>
                    @GetDownloadStatusText(detail)
                    @if (CanManuallyDownload(detail))
                    {
                        <button @onclick="() => DownloadNow(detail)">Download</button>
                    }
                    <button class="primary" @onclick="() => PlayRssAsync(detail.Id)">Play</button>
                </p>
            }
            else
            {
                <p>
                    <button class="primary" @onclick="() => PlayYouTubeAsync(detail.Id)">Play</button>
                </p>
            }

            <div class="show-notes">
                @((MarkupString)ShowNotesSanitizer.Sanitize(detail.DescriptionHtml))
            </div>
        }
    </section>
</div>

@code {
    private List<FeedSummary>? feeds;
    private List<EpisodeListItem>? episodes;
    private EpisodeDetail? detail;
    private int? selectedFeedId;
    private int? selectedEpisodeId;
    private bool showArchived;
    private readonly CancellationTokenSource cts = new();

    protected override async Task OnInitializedAsync()
    {
        ProgressTracker.Changed += OnProgressChanged;
        await LoadFeedsAsync();
        await LoadEpisodesAsync();
    }

    private void OnProgressChanged() => InvokeAsync(StateHasChanged);

    private async Task LoadFeedsAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync(cts.Token);
        feeds = await db.Feeds
            .OrderBy(f => f.Title)
            .Select(f => new FeedSummary(
                f.Id,
                f.Title ?? f.OriginalUrl,
                f.Episodes.Count(e => !e.IsArchived),
                f.Episodes.Where(e => !e.IsArchived).Sum(e => e.DurationSeconds) ?? 0,
                f.ArtworkFileName != null))
            .ToListAsync(cts.Token);
    }

    private async Task LoadEpisodesAsync()
    {
        await using var db = await DbContextFactory.CreateDbContextAsync(cts.Token);
        var query = db.Episodes.Where(e => e.IsArchived == showArchived);

        if (selectedFeedId is { } feedId)
        {
            query = query.Where(e => e.FeedId == feedId);
        }

        query = Config.EpisodeSortDescending
            ? query.OrderByDescending(e => e.PublishedAtUtc)
            : query.OrderBy(e => e.PublishedAtUtc);

        var rows = await query
            .Select(e => new
            {
                e.Id,
                e.Title,
                FeedTitle = e.Feed.Title ?? e.Feed.OriginalUrl,
                e.PublishedAtUtc,
                e.DurationSeconds,
                e.ScheduledStartUtc,
                IsShort = e.EnclosureUrl == null && e.DurationSeconds != null && e.DurationSeconds <= 300,
                FeedSlug = e.Feed.Slug,
                e.DownloadedFileName,
            })
            .Take(200)
            .ToListAsync(cts.Token);

        episodes = rows
            .Select(r => new EpisodeListItem(r.Id, r.Title, r.FeedTitle, r.PublishedAtUtc, r.DurationSeconds, r.ScheduledStartUtc, r.IsShort, GetFileSize(r.FeedSlug, r.DownloadedFileName)))
            .ToList();
    }

    private async Task SelectFeedAsync(int? feedId)
    {
        selectedFeedId = feedId;
        selectedEpisodeId = null;
        detail = null;
        await LoadEpisodesAsync();
    }

    private async Task ToggleHideEmptyFeedsAsync(ChangeEventArgs e)
    {
        Config.HideEmptyFeeds = e.Value is true;
        Config.Save();

        if (Config.HideEmptyFeeds && selectedFeedId is { } feedId
            && feeds?.SingleOrDefault(f => f.Id == feedId) is { ActiveCount: 0 })
        {
            await SelectFeedAsync(null);
        }
    }

    private async Task ToggleSortOrderAsync()
    {
        Config.EpisodeSortDescending = !Config.EpisodeSortDescending;
        Config.Save();
        await LoadEpisodesAsync();
    }

    private async Task ToggleShowArchivedAsync(ChangeEventArgs e)
    {
        showArchived = e.Value is true;
        selectedEpisodeId = null;
        detail = null;
        await LoadEpisodesAsync();
    }

    private async Task SelectEpisodeAsync(int episodeId)
    {
        selectedEpisodeId = episodeId;

        await using var db = await DbContextFactory.CreateDbContextAsync(cts.Token);
        var row = await db.Episodes
            .Where(e => e.Id == episodeId)
            .Select(e => new
            {
                e.Id,
                e.Title,
                FeedTitle = e.Feed.Title ?? e.Feed.OriginalUrl,
                e.PublishedAtUtc,
                e.DurationSeconds,
                e.ScheduledStartUtc,
                e.DescriptionHtml,
                e.IsPlayed,
                e.IsArchived,
                IsRss = e.EnclosureUrl != null,
                IsShort = e.EnclosureUrl == null && e.DurationSeconds != null && e.DurationSeconds <= 300,
                e.IsDownloaded,
                FeedSlug = e.Feed.Slug,
                e.DownloadedFileName,
            })
            .SingleOrDefaultAsync(cts.Token);

        detail = row is null
            ? null
            : new EpisodeDetail(row.Id, row.Title, row.FeedTitle, row.PublishedAtUtc, row.DurationSeconds, row.ScheduledStartUtc, row.DescriptionHtml, row.IsPlayed, row.IsArchived, row.IsRss, row.IsShort, row.IsDownloaded, GetFileSize(row.FeedSlug, row.DownloadedFileName));
    }

    private string GetDownloadStatusText(EpisodeDetail current)
    {
        var snapshot = ProgressTracker.Get(current.Id);
        if (snapshot is not null)
        {
            return snapshot.Status switch
            {
                DownloadStatus.Queued => "Queued for download.",
                DownloadStatus.Downloading => $"Downloading... {snapshot.FormatProgress()}",
                DownloadStatus.Completed => "Downloaded.",
                DownloadStatus.Failed => $"Download failed: {snapshot.ErrorMessage}",
                DownloadStatus.Canceled => "Download canceled.",
                _ => string.Empty,
            };
        }

        return current.IsDownloaded ? "Downloaded." : "Not downloaded.";
    }

    private bool CanManuallyDownload(EpisodeDetail current)
    {
        if (current.IsDownloaded)
        {
            return false;
        }

        var snapshot = ProgressTracker.Get(current.Id);
        return snapshot is null or { Status: DownloadStatus.Failed or DownloadStatus.Canceled };
    }

    private void DownloadNow(EpisodeDetail current) =>
        DownloadQueue.Enqueue(current.Id, current.Title, current.FeedTitle);

    private Task PlayRssAsync(int episodeId) => PlaybackService.RequestPlayRssAsync(episodeId, cts.Token);

    private Task PlayYouTubeAsync(int episodeId) => PlaybackService.PlayYouTubeAsync(episodeId, cts.Token);

    private async Task TogglePlayedAsync(EpisodeDetail current)
    {
        if (current.IsPlayed)
        {
            await UnarchiveAsync(current.Id);
        }
        else
        {
            await EpisodeStateService.MarkAsPlayedAsync(current.Id, cts.Token);
            await RefreshAfterMutationAsync(current.Id);
        }
    }

    private async Task UnarchiveAsync(int episodeId)
    {
        await EpisodeStateService.UnarchiveAsync(episodeId, cts.Token);
        await RefreshAfterMutationAsync(episodeId);
    }

    private async Task RefreshAfterMutationAsync(int episodeId)
    {
        await LoadFeedsAsync();

        if (Config.HideEmptyFeeds && selectedFeedId is { } feedId
            && feeds?.SingleOrDefault(f => f.Id == feedId) is { ActiveCount: 0 })
        {
            await SelectFeedAsync(null);
            return;
        }

        await LoadEpisodesAsync();

        if (selectedEpisodeId == episodeId)
        {
            await SelectEpisodeAsync(episodeId);
        }
    }

    private static string FormatDuration(int? seconds)
    {
        if (seconds is null)
        {
            return string.Empty;
        }

        var span = TimeSpan.FromSeconds(seconds.Value);
        return span.TotalHours >= 1 ? span.ToString(@"h\:mm\:ss") : span.ToString(@"m\:ss");
    }

    // An unaired YouTube premiere has no real duration yet; show its scheduled air date
    // in the meta line in place of a "0:00" that would never be accurate.
    private static string FormatDurationOrSchedule(int? seconds, DateTime? scheduledStartUtc) =>
        scheduledStartUtc is { } start
            ? $"Airs {start.ToLocalTime():MMM d, yyyy}"
            : FormatDuration(seconds);

    // Total listening time of the active (new/unplayed) episodes, shown next to each feed
    // and the "All feeds" entry. Always "xh xm" so it aligns column-wise in the sidebar.
    private static string FormatTotalTime(long seconds)
    {
        var totalMinutes = (long)Math.Round(seconds / 60.0, MidpointRounding.AwayFromZero);
        return $"{totalMinutes / 60}h {totalMinutes % 60}m";
    }

    private static string UpcomingTooltip(DateTime? scheduledStartUtc) =>
        scheduledStartUtc is { } start
            ? $"Scheduled premiere — airs {start.ToLocalTime():MMM d, yyyy h:mm tt}"
            : "Scheduled premiere";

    private static long? GetFileSize(string feedSlug, string? downloadedFileName)
    {
        if (downloadedFileName is null)
        {
            return null;
        }

        var filePath = Path.Combine(AppPaths.DownloadsDirectory, feedSlug, downloadedFileName);
        var info = new FileInfo(filePath);
        return info.Exists ? info.Length : null;
    }

    private static string FormatFileSize(long? bytes)
    {
        if (bytes is null)
        {
            return string.Empty;
        }

        const double kb = 1024;
        const double mb = kb * 1024;
        const double gb = mb * 1024;

        return bytes.Value switch
        {
            >= (long)gb => $"{bytes.Value / gb:0.00} GB",
            >= (long)mb => $"{bytes.Value / mb:0.00} MB",
            _ => $"{bytes.Value / kb:0.00} KB",
        };
    }

    public void Dispose()
    {
        ProgressTracker.Changed -= OnProgressChanged;
        cts.Cancel();
        cts.Dispose();
    }

    private sealed record FeedSummary(int Id, string Title, int ActiveCount, long UnplayedSeconds, bool HasArtwork);

    private sealed record EpisodeListItem(int Id, string Title, string FeedTitle, DateTime PublishedAtUtc, int? DurationSeconds, DateTime? ScheduledStartUtc, bool IsShort, long? FileSizeBytes);

    private sealed record EpisodeDetail(int Id, string Title, string FeedTitle, DateTime PublishedAtUtc, int? DurationSeconds, DateTime? ScheduledStartUtc, string? DescriptionHtml, bool IsPlayed, bool IsArchived, bool IsRss, bool IsShort, bool IsDownloaded, long? FileSizeBytes);
}
