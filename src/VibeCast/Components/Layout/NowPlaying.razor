@implements IAsyncDisposable
@inject PlaybackService PlaybackService
@inject IJSRuntime JS
@inject VibeCast.AppHost.AppConfig Config
@using System.Diagnostics
@using VibeCast.Playback

@if (PlaybackService.Current is { } current)
{
    <div class="now-playing @(isExpanded ? "now-playing-expanded" : "")">
        <div class="now-playing-info">
            <div class="now-playing-title">@current.Title</div>
            <div class="now-playing-feed">@current.FeedTitle</div>
        </div>

        <div class="now-playing-media">
            @if (current.IsRss)
            {
                @if (current.IsVideo)
                {
                    <div class="now-playing-video-wrap">
                        <video @ref="audioElement" controls></video>
                    </div>
                }
                else
                {
                    <audio @ref="audioElement" controls></audio>
                }
                <label class="speed-control">
                    Speed
                    <select @bind="rssRate" @bind:after="OnRssRateChangedAsync">
                        @foreach (var rate in RssRates)
                        {
                            <option value="@rate">@rate.ToString("0.0")x</option>
                        }
                    </select>
                </label>
            }
            else
            {
                <div class="now-playing-video-wrap">
                    <div id="@youtubeElementId"></div>
                </div>
                @if (youtubeRates.Count > 0)
                {
                    <label class="speed-control">
                        Speed
                        <select @bind="youtubeRate" @bind:after="OnYouTubeRateChangedAsync">
                            @foreach (var rate in youtubeRates)
                            {
                                <option value="@rate">@rate.ToString("0.0##")x</option>
                            }
                        </select>
                    </label>
                }
                <label class="speed-control">
                    <input type="checkbox" checked="@ccEnabled" @onchange="OnCcChangedAsync" />
                    CC
                </label>
            }
        </div>

        <div class="now-playing-actions">
            @if (current.IsVideo)
            {
                <button @onclick="ToggleExpanded" title="@(isExpanded ? "Collapse" : "Expand")">@(isExpanded ? "⤡" : "⤢")</button>
            }
            <button @onclick="OpenExternal">Open in external app</button>
            <button @onclick="StopPlaybackAsync">Close</button>
        </div>
    </div>
}
else if (PlaybackService.IsAwaitingDownload)
{
    <div class="now-playing now-playing-loading">Downloading episode&hellip; will play automatically when ready.</div>
}

@code {
    private static readonly decimal[] RssRates = Enumerable.Range(10, 21).Select(i => i / 10m).ToArray();

    private readonly string youtubeElementId = $"yt-player-{Guid.NewGuid():N}";
    private ElementReference audioElement;
    private IJSObjectReference? audioModule;
    private IJSObjectReference? youtubeModule;
    private IJSObjectReference? uiModule;
    private DotNetObjectReference<NowPlaying>? dotNetRef;
    private PeriodicTimer? saveTimer;
    private Task? saveLoopTask;
    private readonly CancellationTokenSource lifetimeCts = new();

    private int? loadedEpisodeId;
    private bool loadedIsRss;
    private decimal rssRate = 1.0m;
    private List<double> youtubeRates = [];
    private double youtubeRate = 1.0;
    private bool ccEnabled = true;
    private bool isExpanded;

    protected override void OnInitialized() => PlaybackService.Changed += OnPlaybackChanged;

    private void OnPlaybackChanged()
    {
        if (PlaybackService.Current is null)
        {
            loadedEpisodeId = null;
            isExpanded = false;
        }

        InvokeAsync(StateHasChanged);
    }

    private async Task ToggleExpanded()
    {
        isExpanded = !isExpanded;
        if (uiModule is not null && dotNetRef is not null)
        {
            if (isExpanded)
            {
                await uiModule.InvokeVoidAsync("addEscapeListener", dotNetRef);
            }
            else
            {
                await uiModule.InvokeVoidAsync("removeEscapeListener");
            }
        }
    }

    [JSInvokable]
    public async Task OnEscapePressed()
    {
        if (isExpanded)
        {
            await ToggleExpanded();
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            saveTimer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            saveLoopTask = SavePositionLoopAsync(lifetimeCts.Token);
            uiModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/nowPlayingUi.js");
        }

        var current = PlaybackService.Current;
        if (current is null || (loadedEpisodeId == current.EpisodeId && loadedIsRss == current.IsRss))
        {
            return;
        }

        if (current.IsRss)
        {
            audioModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/audioPlayer.js");
            await audioModule.InvokeVoidAsync("init", audioElement, dotNetRef);
            await audioModule.InvokeVoidAsync("setSource", audioElement, current.MediaUrl, current.InitialPositionSeconds);
            rssRate = Config.DefaultPlaybackSpeed;
            await audioModule.InvokeVoidAsync("setRate", audioElement, (double)rssRate);
        }
        else
        {
            youtubeModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/youtubePlayer.js");
            ccEnabled = Config.ClosedCaptionsEnabled;
            await youtubeModule.InvokeVoidAsync("init", youtubeElementId, current.YouTubeVideoId, current.InitialPositionSeconds, dotNetRef, ccEnabled);
            youtubeRates = (await youtubeModule.InvokeAsync<double[]>("getAvailablePlaybackRates")).ToList();
            // YouTube's embed only honors its own native stepped menu, so pick the
            // closest available rate to the configured default rather than faking it.
            youtubeRate = youtubeRates.Count > 0
                ? youtubeRates.OrderBy(r => Math.Abs(r - (double)Config.DefaultPlaybackSpeed)).First()
                : 1.0;
            await youtubeModule.InvokeVoidAsync("setPlaybackRate", youtubeRate);
            StateHasChanged();
        }

        loadedEpisodeId = current.EpisodeId;
        loadedIsRss = current.IsRss;
    }

    private async Task OnRssRateChangedAsync()
    {
        if (audioModule is not null)
        {
            await audioModule.InvokeVoidAsync("setRate", audioElement, (double)rssRate);
        }
    }

    private async Task OnYouTubeRateChangedAsync()
    {
        if (youtubeModule is not null)
        {
            await youtubeModule.InvokeVoidAsync("setPlaybackRate", youtubeRate);
        }
    }

    private async Task OnCcChangedAsync(ChangeEventArgs e)
    {
        ccEnabled = e.Value is true;
        if (youtubeModule is not null)
        {
            await youtubeModule.InvokeVoidAsync("setCaptionsEnabled", ccEnabled);
        }
    }

    [JSInvokable]
    public Task OnEnded() => PlaybackService.HandlePlaybackEndedAsync(CancellationToken.None);

    [JSInvokable]
    public Task OnPlayStateChanged(bool isPlaying) => Task.CompletedTask;

    private const int YouTubeStateEnded = 0;

    [JSInvokable]
    public Task OnYouTubeStateChange(int state) =>
        state == YouTubeStateEnded ? PlaybackService.HandlePlaybackEndedAsync(CancellationToken.None) : Task.CompletedTask;

    private async Task SavePositionLoopAsync(CancellationToken ct)
    {
        try
        {
            while (saveTimer is not null && await saveTimer.WaitForNextTickAsync(ct))
            {
                await SaveCurrentPositionAsync(ct);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task SaveCurrentPositionAsync(CancellationToken ct)
    {
        var current = PlaybackService.Current;
        if (current is null)
        {
            return;
        }

        try
        {
            double seconds = current.IsRss
                ? audioModule is null ? 0 : await audioModule.InvokeAsync<double>("getCurrentTime", audioElement)
                : youtubeModule is null ? 0 : await youtubeModule.InvokeAsync<double>("getCurrentTime");

            if (seconds > 0)
            {
                await PlaybackService.SavePositionAsync(current.EpisodeId, (int)seconds, ct);
            }
        }
        catch (JSDisconnectedException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private void OpenExternal()
    {
        if (PlaybackService.Current is { } current)
        {
            Process.Start(new ProcessStartInfo(current.ExternalTarget) { UseShellExecute = true });
        }
    }

    private async Task StopPlaybackAsync()
    {
        try
        {
            if (loadedIsRss && audioModule is not null)
            {
                await audioModule.InvokeVoidAsync("pause", audioElement);
            }
            else if (!loadedIsRss && youtubeModule is not null)
            {
                await youtubeModule.InvokeVoidAsync("pause");
            }

            if (isExpanded && uiModule is not null)
            {
                await uiModule.InvokeVoidAsync("removeEscapeListener");
            }
        }
        catch (JSDisconnectedException)
        {
        }

        loadedEpisodeId = null;
        isExpanded = false;
        PlaybackService.Stop();
    }

    public async ValueTask DisposeAsync()
    {
        PlaybackService.Changed -= OnPlaybackChanged;
        lifetimeCts.Cancel();
        saveTimer?.Dispose();

        if (saveLoopTask is not null)
        {
            try
            {
                await saveLoopTask;
            }
            catch
            {
            }
        }

        lifetimeCts.Dispose();
        dotNetRef?.Dispose();

        try
        {
            if (audioModule is not null)
            {
                await audioModule.DisposeAsync();
            }

            if (youtubeModule is not null)
            {
                await youtubeModule.DisposeAsync();
            }

            if (uiModule is not null)
            {
                await uiModule.InvokeVoidAsync("removeEscapeListener");
                await uiModule.DisposeAsync();
            }
        }
        catch (JSDisconnectedException)
        {
        }
    }
}
