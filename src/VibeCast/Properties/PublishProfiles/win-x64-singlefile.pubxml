<Project>
  <!--
    Phase 8 packaging target (CLAUDE.md: "Windows x64 only. Single self-contained
    single-file publish."). Run with:
      dotnet publish src/VibeCast/VibeCast.csproj -c Release -p:PublishProfile=win-x64-singlefile
    Output lands in bin/Release/net10.0-windows/win-x64/publish/. Copy that whole
    folder (VibeCast.exe plus wwwroot/ and any native deps) to ship; static web
    assets aren't embedded into the single file, so wwwroot/ stays a sibling folder.
  -->
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
  </PropertyGroup>
</Project>
